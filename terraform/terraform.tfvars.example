# ============================================================================
# TERRAFORM VARIABLES - EXAMPLE FILE
# 
# Copy this to terraform.tfvars and fill in your values:
# $ cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: 
# - terraform.tfvars is in .gitignore (don't commit credentials)
# - Keep sensitive values in terraform.tfvars, not in version control
# ============================================================================

# Azure subscription ID
# Get with: az account show --query id -o tsv
azure_subscription_id = "00000000-0000-0000-0000-000000000000"

# Environment: dev, staging, or prod
environment = "dev"

# Azure region
location = "eastus"

# Resource group name
resource_group_name = "bloom-discord-bot"

# Function App name (must be globally unique)
function_app_name = "bloom-discord-bot"

# Storage account name (must be globally unique, lowercase, 3-24 chars)
storage_account_name = "bloomdiscordbotst"

# Discord Public Key
# Get from Discord Developer Portal > Application > General Information
discord_public_key = "YOUR_DISCORD_PUBLIC_KEY_HERE"

# Discord Bot Token (optional - for reference only)
discord_bot_token = ""

# Cosmos DB account name
cosmos_db_name = "bloom-cosmos-db"

# Python version for Function App
python_version = "3.11"

# Function App SKU
# Y1 = Consumption (pay per invocation, ~$0.01 per 100k invocations)
# B1 = Basic (~$50/month)
# P1V2 = Premium V2 (~$100+/month)
function_app_sku = "Y1"

# Log retention in days
log_retention_days = 30

# Tags to apply to all resources
tags = {
  Project     = "Bloom"
  Component   = "Discord-Bot"
  Environment = "dev"
  ManagedBy   = "Terraform"
  Owner       = "Your Name"
}
